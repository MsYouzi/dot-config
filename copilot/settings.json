{
  "model": "gpt-5.5",
  "contextTier": "long_context",
  "theme": "dark",
  "renderMarkdown": true,
  "logLevel": "all",
  "experimental": true,
  "banner": "always",
  "beep": true,
  "mouse": true,
  "stream": true,
  "keepAlive": "busy",
  "continueOnAutoMode": true,
  "updateTerminalTitle": true,
  "compactPaste": true,
  "respectGitignore": true,
  "includeCoAuthoredBy": true,
  "footer": {
    "showModelEffort": false,
    "showDirectory": false,
    "showBranch": false,
    "showContextWindow": false,
    "showQuota": false,
    "showAgent": false,
    "showCodeChanges": false,
    "showUsername": false,
    "showCustom": true
  },
  "statusLine": {
    "type": "command",
    "command": "~/.copilot/statusline.sh"
  },
  "ide": {
    "autoConnect": true,
    "openDiffOnEdit": true
  },
  "effortLevel": "xhigh",
  "sessionSync": [
    {
      "origin": "D0n9X1n/nvim-config",
      "level": "user"
    },
    {
      "origin": "D0n9X1n/chatgpt-tag-highlighter",
      "level": "user"
    },
    {
      "origin": "D0n9X1n/dot-config",
      "level": "user"
    },
    {
      "origin": "*",
      "level": "local"
    }
  ],
  "showReasoning": false
}
